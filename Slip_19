package main 
import ( 
    "bufio" 
    "fmt" 
    "os" 
) 
func main() { 
    var filename string 
    fmt.Print("Enter filename: ") 
    fmt.Scan(&filename) 
    file, err := os.OpenFile(filename, os.O_RDONLY, 0444) 
    if err != nil { 
        fmt.Println("Error:", err) 
        return 
    } 
    defer file.Close() 
    fmt.Println("Contents:") 
    scanner := bufio.NewScanner(file) 
    for scanner.Scan() { 
        fmt.Println(scanner.Text()) 
    } 
} 

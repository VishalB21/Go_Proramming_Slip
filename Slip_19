package main 
import "fmt" 
func addSub(a, b int) (int, int) { 
    return a + b, a - b 
} 
func main() { 
    var a, b int 
    fmt.Print("Enter two numbers: ") 
    fmt.Scan(&a, &b) 
    sum, diff := addSub(a, b) 
    fmt.Printf("Sum        = %d\nDifference = %d\n", sum, diff) 
} 


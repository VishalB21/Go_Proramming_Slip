package main 
import ( 
    "fmt" 
    "os" 
) 
func main() { 
    file, err := os.Create("myfile.txt") 
    if err != nil { 
        fmt.Println("Error:", err) 
        return 
    } 
    defer file.Close() 
    file.WriteString("Hello, Go!\n") 
    fmt.Println("File created successfully!") 
} 


package main 
import "fmt" 
type Employee struct { 
    Eno    int 
    Ename  string 
    Salary float64 
} 
func main() { 
    var n int 
    fmt.Print("Enter number of employees: ") 
    fmt.Scan(&n) 
    emps := make([]Employee, n) 
    for i := 0; i < n; i++ { 
        fmt.Printf("Enter eno, ename, salary: ") 
        fmt.Scan(&emps[i].Eno, &emps[i].Ename, &emps[i].Salary) 
    } 
    min := emps[0] 
    for _, e := range emps[1:] { 
        if e.Salary < min.Salary { 
            min = e 
        } 
    } 
    fmt.Printf("Min Salary: Eno=%d Name=%s Salary=%.2f\n", 
        min.Eno, min.Ename, min.Salary) 
}

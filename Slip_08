package main 
import "fmt" 
type Book struct { 
    BookID int 
    Title  string 
    Author string 
    Price  float64 
} 
func main() { 
    var n int 
    fmt.Print("Enter number of books: ") 
    fmt.Scan(&n) 
    books := make([]Book, n) 
    for i := 0; i < n; i++ { 
        fmt.Printf("Enter BookID, Title, Author, Price: ") 
        fmt.Scan(&books[i].BookID, &books[i].Title, 
            &books[i].Author, &books[i].Price) 
    } 
    for _, b := range books { 
        fmt.Printf("ID:%d | %s | %s | %.2f\n", 
            b.BookID, b.Title, b.Author, b.Price) 
    } 
} 


package main 
import "fmt" 
func printTable(n int) { 
    fmt.Printf("Table of %d:\n", n) 
    for i := 1; i <= 10; i++ { 
        fmt.Printf("%d x %d = %d\n", n, i, n*i) 
    } 
} 
func main() { 
    var n int 
    fmt.Print("Enter a number: ") 
    fmt.Scan(&n) 
    printTable(n) 
} 


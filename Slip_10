package main 
import "fmt" 
func printType(i interface{}) { 
    switch v := i.(type) { 
    case int: 
        fmt.Printf("int    : %d\n", v) 
    case float64: 
        fmt.Printf("float64: %.2f\n", v) 
    case string: 
        fmt.Printf("string : %s\n", v) 
    case bool: 
        fmt.Printf("bool   : %v\n", v) 
    default: 
        fmt.Printf("unknown: %T\n", v) 
    } 
} 
func main() { 
    values := []interface{}{42, 3.14, "Hello Go", true} 
    for _, val := range values { 
        printType(val) 
    } 
}


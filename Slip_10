package main 
import "fmt" 
func fibonacci(n int, ch chan int) { 
    a, b := 0, 1 
    for i := 0; i < n; i++ { 
        ch <- a 
        a, b = b, a+b 
    } 
    close(ch) 
} 
func main() { 
    var n int 
    fmt.Print("Enter terms: ") 
    fmt.Scan(&n) 
    ch := make(chan int) 
    go fibonacci(n, ch) 
    fmt.Print("Fibonacci: ") 
    for val := range ch { 
        fmt.Print(val, " ") 
} 
fmt.Println() 

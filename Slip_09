package main 
import "fmt" 
func isPalindrome(s string) bool { 
    reversed := "" 
    for i := len(s) - 1; i >= 0; i-- { 
        reversed += string(s[i]) 
    } 
    return s == reversed 
} 
func main() { 
    str := "madam" 
    if isPalindrome(str) { 
        fmt.Println("Palindrome") 
    } else { 
        fmt.Println("Not Palindrome") 
    } 
} 


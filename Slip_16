package rect 
 
func Area(l, w float64) float64 { 
    return l * w 
} 
func Perimeter(l, w float64) float64 { 
    return 2 * (l + w) 
} 
 
// File: main.go 
package main 
import ( 
    "fmt" 
    "rect" 
) 
func main() { 
    var l, w float64 
    fmt.Print("Enter length and width: ") 
    fmt.Scan(&l, &w) 
    fmt.Printf("Area      = %.2f\n", rect.Area(l, w)) 
    fmt.Printf("Perimeter = %.2f\n", rect.Perimeter(l, w)) 
} 


package main 
import ( 
    "fmt" 
    "time" 
) 
func square(n int) int { 
    return n * n 
} 
func main() { 
    var n int 
    fmt.Print("Enter a number: ") 
    fmt.Scan(&n) 
    fmt.Printf("Square of %d = %d\n", n, square(n)) 
    start := time.Now() 
    for i := 0; i < 1000000; i++ { 
        square(i) 
    } 
    fmt.Printf("Benchmark: 1M calls took %v\n", time.Since(start)) 
}   main.go 

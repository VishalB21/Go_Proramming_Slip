package main 
import "fmt" 
func calculate(a, b float64) (float64, float64, float64, float64) { 
    return a + b, a - b, a * b, a / b 
} 
func main() { 
    var a, b float64 
    fmt.Print("Enter two numbers: ") 
    fmt.Scan(&a, &b) 
    add, sub, mul, div := calculate(a, b) 
    fmt.Printf("Add = %.2f\nSub = %.2f\nMul = %.2f\nDiv = %.2f\n", 
        add, sub, mul, div) 
} 


package main 
import ( 
    "fmt" 
    "os" 
) 
func main() { 
    file, err := os.OpenFile("data.txt", 
        os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644) 
    if err != nil { 
        fmt.Println("Error:", err) 
        return 
    } 
    defer file.Close() 
    var text string 
    fmt.Print("Enter text to append: ") 
    fmt.Scan(&text) 
    file.WriteString(text + "\n") 
    fmt.Println("Appended successfully!") 
} 

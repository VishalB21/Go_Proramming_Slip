package main 
import "fmt" 
func main() { 
    s := []int{10, 20, 30, 40, 50} 
    fmt.Println("Original:", s) 
    s = append(s, 60, 70) 
    fmt.Println("Append  :", s) 
    s2 := make([]int, len(s)) 
    copy(s2, s) 
    fmt.Println("Copy    :", s2) 
    s = append(s[:2], s[3:]...) 
    fmt.Println("Remove  :", s) 
    fmt.Printf("Len=%d Cap=%d\n", len(s), cap(s)) 
} 


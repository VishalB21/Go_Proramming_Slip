package main 
import ( 
    "fmt" 
    "sync" 
) 
func sumSquares(digits []int, ch chan<- int, wg *sync.WaitGroup) { 
    defer wg.Done() 
    sum := 0 
    for _, d := range digits { 
        sum += d * d 
    } 
    ch <- sum 
} 
func sumCubes(digits []int, ch chan<- int, wg *sync.WaitGroup) { 
    defer wg.Done() 
    sum := 0 
    for _, d := range digits { 
        sum += d * d * d 
    } 
    ch <- sum 
} 
